# Public site URL (SEO / Open Graph)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Terminal (required on Vercel) ---
# Vercel only hosts the Next.js UI. Deploy `npm run terminal:server` on Railway/Fly/Docker,
# then set this to that backend URL (no trailing slash):
# NEXT_PUBLIC_TERMINAL_SOCKET_URL=https://your-terminal-backend.railway.app

# Allow browser on Vercel to connect to the terminal backend (comma-separated):
# TERMINAL_CORS_ORIGIN=https://rio-terminal.vercel.app,https://www.your-domain.com

# Shell working directory (default: user home ~)
# TERMINAL_CWD=~
